# Telegram bot token from @BotFather
TOKEN=

# Telegram numeric chat id that receives logs/alerts (0 to disable)
ADMIN_CHAT_ID=0

# Optional: external host for serving files larger than Telegram's 50MB limit.
# Files are uploaded via scp and self-delete after the first full download.
# Leave DL_SSH_HOST blank to disable this fallback.
DL_BASE_URL=
DL_SSH_HOST=
DL_SSH_USER=
DL_REMOTE_DIR=
DL_SSH_KEY=
